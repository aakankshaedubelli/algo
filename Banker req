#include <stdio.h>

int main() {
    int n = 5, m = 3;

    int alloc[5][3] = {
        {0,1,0},{2,0,0},{3,0,2},{2,1,1},{0,0,2}
    };

    int max[5][3] = {
        {7,5,3},{3,2,2},{9,0,2},{2,2,2},{4,3,3}
    };

    int avail[3] = {3,3,2};

    int need[5][3];

    for(int i=0;i<n;i++)
        for(int j=0;j<m;j++)
            need[i][j] = max[i][j] - alloc[i][j];

    int process = 1; // P1 requesting
    int request[3] = {1,0,2};

    // Step 1: Request <= Need
    for(int i=0;i<m;i++) {
        if(request[i] > need[process][i]) {
            printf("Error: exceeds need\n");
            return 0;
        }
    }

    // Step 2: Request <= Available
    for(int i=0;i<m;i++) {
        if(request[i] > avail[i]) {
            printf("Wait: resources not available\n");
            return 0;
        }
    }

    // Step 3: Pretend allocation
    for(int i=0;i<m;i++) {
        avail[i] -= request[i];
        alloc[process][i] += request[i];
        need[process][i] -= request[i];
    }

    printf("Request granted (safe state assumed)\n");
}
