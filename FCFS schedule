#include <stdio.h>

int main() {
    int n;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    int arrival[n], burst[n], pid[n];

    // Input arrival times
    printf("Enter Arrival Time for each process:\n");
    for (int i = 0; i < n; i++) {
        scanf("%d", &arrival[i]);
        pid[i] = i + 1;  // store original process number
    }

    // Input burst times
    printf("Enter Burst Time for each process:\n");
    for (int i = 0; i < n; i++) {
        scanf("%d", &burst[i]);
    }

    // Sort processes by arrival time (simple bubble sort)
    for (int i = 0; i < n-1; i++) {
        for (int j = 0; j < n-i-1; j++) {
            if (arrival[j] > arrival[j+1]) {
                // Swap arrival times
                int temp = arrival[j];
                arrival[j] = arrival[j+1];
                arrival[j+1] = temp;
                
                // Swap burst times
                temp = burst[j];
                burst[j] = burst[j+1];
                burst[j+1] = temp;

                // Swap process IDs
                temp = pid[j];
                pid[j] = pid[j+1];
                pid[j+1] = temp;
            }
        }
    }

    int time = 0;

    printf("\nFCFS Scheduling Results:\n\n");

    printf("P\tAT\tBT\tST\tCT\tTAT\tWT\n");
    for (int i = 0; i < n; i++) {
        if (time < arrival[i]) {
            time = arrival[i]; // CPU idle till process arrives
        }

        int start = time;
        int completion = start + burst[i];
        int turnaround = completion - arrival[i];
        int waiting = turnaround - burst[i];

        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n", 
                pid[i], arrival[i], burst[i], start, completion, turnaround, waiting);

        time = completion;
    }

    return 0;
}
