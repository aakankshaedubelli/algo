#include <stdio.h>

int main() {
    int frames, pages, i, j, faults = 0, time = 0;

    printf("Enter number of frames: ");
    scanf("%d", &frames);

    printf("Enter number of pages: ");
    scanf("%d", &pages);

    int frame[frames], page[pages], recent[frames];

    printf("Enter page reference string:\n");
    for(i = 0; i < pages; i++)
        scanf("%d", &page[i]);

    for(i = 0; i < frames; i++) {
        frame[i] = -1;
        recent[i] = 0;
    }

    printf("\nPage\t");
    for(i = 0; i < frames; i++)
        printf("F%d\t", i+1);
    printf("Fault\n");

    for(i = 0; i < pages; i++) {
        int found = 0;

        for(j = 0; j < frames; j++) {
            if(frame[j] == page[i]) {
                time++;
                recent[j] = time;
                found = 1;
                break;
            }
        }

        if(!found) {
            int min = recent[0], pos = 0;

            for(j = 1; j < frames; j++) {
                if(recent[j] < min) {
                    min = recent[j];
                    pos = j;
                }
            }

            frame[pos] = page[i];
            time++;
            recent[pos] = time;
            faults++;
        }

        printf("%d\t", page[i]);
        for(j = 0; j < frames; j++)
            printf("%d\t", frame[j]);

        if(!found) printf("F");
        printf("\n");
    }

    printf("Total Page Faults = %d\n", faults);
    return 0;
}
